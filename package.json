{
  "name": "code-snippet-manager",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "server",
    "client"
  ],
  "scripts": {
    "dev:server": "npm run dev --workspace server",
    "dev:client": "npm run dev --workspace client",
    "build": "npm run build --workspace server && npm run build --workspace client",
    "start": "npm run start --workspace server",
    "db:init": "npm run db:init --workspace server",
    "seed": "npm run seed --workspace server",
    "setup": "npm run db:init --workspace server && npm run seed --workspace server"
  }
}
